---
import BrandMark from './BrandMark.astro';

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="inner">
      <!-- Logo -->
      <a href="/#hero" class="logo" aria-label="맨 위로">
        <BrandMark showName />
      </a>

      <!-- Location + tagline -->
      <p class="tagline">
        <span class="loc-icon">📍</span> Daegu, Korea ·
        Frontend Engineer who ships with purpose
      </p>

      <!-- Copy -->
      <p class="copy">
        © {year} Sangmin Park. Built with
        <a href="https://astro.build" target="_blank" rel="noopener" class="built-link">Astro</a>
        &amp; ☕ in Daegu.
      </p>
    </div>
  </div>
</footer>

<style lang="scss">
  @use '../styles/tokens' as *;

  footer {
    background: $bg-base;
    border-top: 1px solid $border;
    padding: 40px 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .tagline {
    font-size: 0.82rem;
    color: $text-muted;
  }

  .loc-icon { font-style: normal; }

  .copy {
    font-size: 0.78rem;
    color: $text-muted;
  }

  .built-link {
    color: $accent;
    text-decoration: none;
    font-weight: 600;

    &:hover { text-decoration: underline; }
  }
</style>
