---

<section id="contact">
  <div class="container">
    <!-- Ambient blobs -->
    <div class="blob b1" aria-hidden="true"></div>
    <div class="blob b2" aria-hidden="true"></div>

    <div class="inner reveal">
      <span class="section-label">CONTACT</span>
      <h2 class="headline">
        함께 만들어갈<br />
        <span class="grad-text">다음 프로젝트</span>
      </h2>
      <p class="sub">
        프로덕트 임팩트를 함께 만들 기회를 찾고 있습니다.<br />
        어떤 형태든 편하게 연락 주세요.
      </p>

      <!-- Email CTA -->
      <a
        href="mailto:qtaghdi@gmail.com"
        class="email-btn"
        aria-label="이메일 보내기"
      >
        <span class="email-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </span>
        <span class="email-text">qtaghdi@gmail.com</span>
        <span class="email-arrow">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      <!-- Social links -->
      <div class="social-grid">
        {links.map(l => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-card"
            style={`--link-color: ${l.color};`}
          >
            <span class="social-icon" set:html={l.icon}></span>
            <div class="social-info">
              <span class="social-label">{l.label}</span>
              <span class="social-username">{l.username}</span>
            </div>
            <svg class="social-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use '../styles/tokens' as *;

  section {
    padding: 120px 0;
    background: $bg-elevated;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  // Blobs — 모노크롬 화이트
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    pointer-events: none;
    background: rgba(255,255,255,1);
  }

  .b1 {
    width: 500px;
    height: 400px;
    opacity: 0.025;
    top: -100px;
    left: -150px;
  }

  .b2 {
    width: 400px;
    height: 350px;
    opacity: 0.018;
    bottom: -80px;
    right: -120px;
  }

  // Inner content
  .inner {
    text-align: center;
  }

  .headline {
    font-family: $font-display;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.2;
    color: $text-primary;
    margin: 12px 0 20px;
  }

  .sub {
    font-size: 1rem;
    color: $text-secondary;
    line-height: 1.8;
    margin-bottom: 48px;
  }

  // Email CTA button
  .email-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #ffffff;
    color: #000000;
    text-decoration: none;
    border-radius: 3px;
    padding: 15px 28px;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    font-family: $font-mono;
    margin-bottom: 48px;
    border: 1px solid #ffffff;
    transition: background-color $mid, color $mid, transform $mid;

    &:hover {
      background: transparent;
      color: #ffffff;
      transform: translateY(-2px);
    }
  }

  .email-icon {
    display: flex;
    opacity: 0.9;
  }

  .email-arrow {
    display: flex;
    margin-left: 4px;
    opacity: 0.8;
    transition: transform $fast;

    .email-btn:hover & { transform: translateX(4px); }
  }

  // Social grid
  .social-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;

    @media (max-width: 560px) {
      grid-template-columns: 1fr;
    }
  }

  .social-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: transparent;
    border: 1px solid $border;
    border-radius: 3px;
    padding: 16px;
    text-decoration: none;
    transition: border-color $mid, transform $mid, background $mid;

    &:hover {
      border-color: rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.03);
      transform: translateY(-2px);

      .social-icon { color: $text-primary; }
      .social-arrow { opacity: 1; transform: translate(2px, -2px); }
    }
  }

  .social-icon {
    color: $text-secondary;
    transition: color $fast;
    flex-shrink: 0;
    display: flex;
  }

  .social-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
    flex: 1;
    min-width: 0;
  }

  .social-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: $text-primary;
  }

  .social-username {
    font-size: 0.72rem;
    color: $text-muted;
    font-family: $font-mono;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .social-arrow {
    color: $text-muted;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity $fast, transform $fast;
  }
</style>
