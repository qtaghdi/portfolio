---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.slug.replace(/^\d+-/, '') },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
const { data } = project;
---

<BaseLayout title={`${data.title} — 박상민 포트폴리오`} description={data.summary}>
  <Navbar />
  <main id="main-content" class="project-page">
    <header class="project-hero">
      <div class="project-shell">
        <a class="back-link" href="/#projects"><span aria-hidden="true">←</span> 프로젝트 목록</a>
        <div class="eyebrow-row">
          <span>{data.category}</span>
          <span aria-hidden="true">·</span>
          <span>{data.year}</span>
        </div>
        <h1>{data.title}</h1>
        {data.titleKo && <p class="title-ko">{data.titleKo}</p>}
        <p class="project-summary">{data.summary}</p>

        <div class="project-meta">
          <div><span>Role</span><strong>{data.role}</strong></div>
          <div><span>Stack</span><strong>{data.tech.slice(0, 4).join(' · ')}</strong></div>
        </div>

        <div class="project-actions">
          {data.link && <a class="btn-primary" href={data.link} target="_blank" rel="noopener">사이트 보기 <span aria-hidden="true">↗</span></a>}
          {data.github && <a class="btn-secondary" href={data.github} target="_blank" rel="noopener">GitHub <span aria-hidden="true">↗</span></a>}
        </div>
      </div>
    </header>

    <div class="project-shell project-content-grid">
      <aside class="project-sidebar" aria-label="프로젝트 정보">
        {data.metrics.length > 0 && (
          <div class="detail-metrics">
            {data.metrics.map((metric) => (
              <div class="detail-metric">
                <strong>{metric.val}</strong>
                <span>{metric.label}</span>
              </div>
            ))}
          </div>
        )}

        <div class="detail-stack">
          <h2>Tech Stack</h2>
          <div>{data.tech.map((item) => <span class="tech-pill">{item}</span>)}</div>
        </div>
      </aside>

      <article class="project-prose">
        {data.callouts.length > 0 && (
          <section class="detail-callouts" aria-label="핵심 구현">
            {data.callouts.map((callout) => (
              <div class="detail-callout">
                <h2><span aria-hidden="true">{callout.icon}</span> {callout.title}</h2>
                <p>{callout.body}</p>
              </div>
            ))}
          </section>
        )}
        <Content />
      </article>
    </div>

    <div class="project-shell project-footer-nav">
      <a href="/#projects"><span aria-hidden="true">←</span> 다른 프로젝트 보기</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style lang="scss">
  @use '../../styles/tokens' as *;

  .project-page { min-height: 100vh; background: $bg-base; }
  .project-shell { width: min(1120px, calc(100% - 48px)); margin: 0 auto; }

  .project-hero {
    padding: 132px 0 72px;
    border-bottom: 1px solid $border;
    background: radial-gradient(circle at 78% 20%, rgba(255,255,255,.07), transparent 30%);
  }

  .back-link, .project-footer-nav a {
    display: inline-flex; align-items: center; gap: 8px;
    color: $text-secondary; font-size: .86rem; font-weight: 600;
    transition: color $fast, gap $fast;
    &:hover { color: $text-primary; gap: 12px; }
  }

  .eyebrow-row {
    display: flex; gap: 10px; margin: 42px 0 18px;
    color: $text-muted; font: 600 .72rem/1.4 $font-mono;
    letter-spacing: .08em; text-transform: uppercase;
  }

  h1 {
    max-width: 900px; color: $text-primary; font-family: $font-display;
    font-size: clamp(2.5rem, 7vw, 6rem); line-height: .98; letter-spacing: -.045em;
    text-wrap: balance;
  }

  .title-ko { margin-top: 14px; color: $text-muted; font-size: 1rem; }
  .project-summary { max-width: 760px; margin-top: 30px; color: $text-secondary; font-size: clamp(1.05rem, 2vw, 1.3rem); line-height: 1.75; text-wrap: pretty; }

  .project-meta {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 760px; gap: 1px; margin-top: 42px; border: 1px solid $border; background: $border;
    > div { padding: 18px 20px; background: $bg-surface; min-width: 0; }
    span { display: block; margin-bottom: 6px; color: $text-muted; font: 600 .68rem/1 $font-mono; text-transform: uppercase; letter-spacing: .1em; }
    strong { display: block; color: $text-primary; font-size: .9rem; line-height: 1.55; overflow-wrap: anywhere; }
  }

  .project-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }

  .project-content-grid {
    display: grid; grid-template-columns: 260px minmax(0, 1fr); gap: clamp(44px, 8vw, 100px);
    padding-top: 72px; padding-bottom: 96px;
  }

  .project-sidebar { min-width: 0; }
  .detail-metrics { display: grid; gap: 1px; padding: 1px; background: $border; }
  .detail-metric {
    padding: 18px; background: $bg-card;
    strong { display: block; color: $text-primary; font: 800 1.5rem/1 $font-display; }
    span { display: block; margin-top: 7px; color: $text-secondary; font-size: .72rem; line-height: 1.45; white-space: pre-line; }
  }

  .detail-stack {
    margin-top: 34px;
    h2 { margin-bottom: 14px; color: $text-primary; font: 700 .78rem/1 $font-mono; letter-spacing: .09em; text-transform: uppercase; }
    > div { display: flex; flex-wrap: wrap; gap: 6px; }
  }

  .project-prose { min-width: 0; color: $text-secondary; }
  .project-prose :global(> h2) {
    margin: 72px 0 20px; color: $text-primary; font: 700 clamp(1.55rem, 3vw, 2.25rem)/1.2 $font-display;
    letter-spacing: -.025em; text-wrap: balance;
  }
  .project-prose :global(> h2:first-of-type) { margin-top: 0; }
  .project-prose :global(p) { margin: 0 0 1.25em; font-size: 1rem; line-height: 1.9; text-wrap: pretty; overflow-wrap: anywhere; }
  .project-prose :global(strong) { color: $text-primary; }
  .project-prose :global(code) { padding: .15em .38em; border: 1px solid $border; border-radius: 3px; background: $bg-elevated; color: #ededed; font-family: $font-mono; font-size: .88em; overflow-wrap: anywhere; }
  .project-prose :global(a) { color: #fff; text-decoration: underline; text-underline-offset: 3px; }

  .detail-callouts { display: grid; gap: 12px; margin-bottom: 64px; }
  .detail-callout {
    padding: 22px; border: 1px solid $border; border-radius: $r-md; background: $bg-card;
    h2 { margin-bottom: 10px; color: $text-primary; font-size: 1rem; }
    p { margin: 0; color: $text-secondary; font-size: .9rem; line-height: 1.75; }
  }

  .project-footer-nav { padding: 0 0 96px; }

  @media (max-width: 760px) {
    .project-shell { width: min(100% - 32px, 1120px); }
    .project-hero { padding: 112px 0 56px; }
    .project-meta { grid-template-columns: 1fr; }
    .project-content-grid { grid-template-columns: 1fr; gap: 52px; padding-top: 52px; }
    .project-sidebar { order: 2; }
    .project-prose { order: 1; }
    .detail-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 460px) {
    .detail-metrics { grid-template-columns: 1fr; }
  }
</style>
